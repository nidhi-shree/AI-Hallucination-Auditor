# ──────────────────────────────────────────────────────────────────────────────
# FactVibe — .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
*.env.local
*.env.*.local

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# ── Distribution / build ──────────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
.eggs/

# ── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── reports & exports ───────────────────────────────────────────────
*.pdf
*.docx
reports/

# ── IDE & editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-workspace
*.sublime-project

# ── OS generated ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Pytest / coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# ── Pyrefly / mypy / type checkers ───────────────────────────────────────────
.mypy_cache/
.pyrefly_cache/
.dmypy.json
dmypy.json

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Temporary / scratch files ─────────────────────────────────────────────────
*.tmp
*.bak
*.swp
__test_*.py
